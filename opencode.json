{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "operator",
  "mcp": {
    "kluky": {
      "type": "local",
      "command": ["uv", "run", "--python", "3.13", "-m", "kluky_mcp.server"],
      "enabled": true
    }
  },
  "provider": {
    "fiit": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "FIIT OpenAI-Compatible",
      "options": {
        "baseURL": "https://litellm.blockfinlab.xyz"
      },
      "models": {
        "gpt-4.1-nano-fiit": { "name": "gpt-4.1-nano-fiit" },
        "gpt-4.1-mini-fiit": { "name": "gpt-4.1-mini-fiit" },
        "gpt-5-fiit": { "name": "gpt-5-fiit" },
        "claude-haiku-4.5-fiit": { "name": "claude-haiku-4.5-fiit" },
        "gpt-4.1-fiit": { "name": "gpt-4.1-fiit" },
        "claude-sonnet-4.5-fiit": { "name": "claude-sonnet-4.5-fiit" },
        "whisper-fiit": { "name": "whisper-fiit" },
        "gpt-4o-mini-transcribe-fiit": {
          "name": "gpt-4o-mini-transcribe-fiit"
        },
        "gpt-4o-transcribe-fiit": { "name": "gpt-4o-transcribe-fiit" }
      }
    }
  }
}
